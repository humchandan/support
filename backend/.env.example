# Database connection (Prisma compatible MySQL/MariaDB url)
DATABASE_URL="mysql://user:password@localhost:3306/aries_mlm"

# Aries local or production RPC URL
NEXT_PUBLIC_ARIES_RPC_URL="http://127.0.0.1:8545"

# Redis server connection details
REDIS_HOST="127.0.0.1"
REDIS_PORT=6379

# Cryptographic token secret
JWT_SECRET="your_secure_jwt_random_key_here"
