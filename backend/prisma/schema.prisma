// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider   = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model User {
  id             Int      @id @default(autoincrement())
  walletAddress  String   @unique
  name           String
  mobile         String
  sponsorAddress String
  proxyAddress   String?  @unique
  rank           String   @default("Default")
  createdAt      DateTime @default(now())

  @@index([walletAddress])
  @@index([sponsorAddress])
}

model StakingPlan {
  id          Int      @id @default(autoincrement())
  userAddress String
  amount      Decimal  @db.Decimal(20, 8)
  txHash      String   @unique
  timestamp   DateTime @default(now())

  @@index([userAddress])
}

model LedgerEntry {
  id          Int      @id @default(autoincrement())
  userAddress String
  type        String
  amount      Decimal  @db.Decimal(20, 8)
  netAmount   Decimal  @db.Decimal(20, 8)
  fee         Decimal  @db.Decimal(20, 8)
  description String
  txHash      String?
  timestamp   DateTime @default(now())

  @@index([userAddress])
}

model ClaimHistory {
  id          Int      @id @default(autoincrement())
  userAddress String
  grossAmount Decimal  @db.Decimal(20, 8)
  netAmount   Decimal  @db.Decimal(20, 8)
  destination String
  timestamp   DateTime @default(now())

  @@index([userAddress])
}

model MlmTier {
  id                 Int      @id @default(autoincrement())
  name               String   @unique
  minSelfInvestment  Decimal  @db.Decimal(20, 8)
  minDirects         Int
  minTeamVolume      Decimal  @db.Decimal(20, 8)
  unlockedLevels     Int
}

model MlmLevel {
  id           Int      @id @default(autoincrement())
  level        Int      @unique
  bonus        Decimal  @db.Decimal(5, 2)
  requiredRank String
}

model UtilityCategory {
  id       Int              @id @default(autoincrement())
  name     String           @unique
  icon     String           // FontAwesome icon class (e.g. "fa-mobile-screen")
  isActive Boolean          @default(true)
  services UtilityService[]
}

model UtilityService {
  id          Int             @id @default(autoincrement())
  categoryId  Int
  name        String
  description String
  minAmount   Decimal         @db.Decimal(20, 8)
  maxAmount   Decimal         @db.Decimal(20, 8)
  isActive    Boolean         @default(true)
  category    UtilityCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  requests    UtilityRequest[]
}

model UtilityRequest {
  id           Int            @id @default(autoincrement())
  userAddress  String
  serviceId    Int
  serviceName  String
  categoryName String
  details      String         @db.Text // JSON string containing user inputs
  amount       Decimal        @db.Decimal(20, 8)
  status       String         @default("PENDING") // PENDING, APPROVED, REJECTED
  adminNotes   String?
  timestamp    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  service      UtilityService @relation(fields: [serviceId], references: [id])

  @@index([userAddress])
  @@index([status])
}

